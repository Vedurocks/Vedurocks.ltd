# ==========================================
# VEDUROCKS BACKEND CONFIGURATION TEMPLATE
# ==========================================
# 1. Copy this file to .env
# 2. Fill in your real values
# 3. NEVER commit .env to GitHub!

# Server Configuration
PORT=8080
NODE_ENV=development

# Frontend URL (your deployed frontend)
# Example: https://vedurocks.vercel.app
# Example: https://yourname.github.io/vedurocks
FRONTEND_URL=https://your-frontend-url-here.com

# ==========================================
# GITHUB OAUTH SETTINGS
# ==========================================
# Get these from: https://github.com/settings/developers
# Create New OAuth App → Fill form → Copy Client ID and Secret

GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=ghs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# SECURITY KEYS (Generate strong random strings)
# ==========================================
# Generate with: openssl rand -base64 32
# Or use: https://randomkeygen.com/

JWT_SECRET=change_this_to_random_string_min_32_characters_long
COOKIE_SECRET=another_random_string_for_cookies_at_least_32_chars

# ==========================================
# DATABASE (Optional - Free at mongodb.com/atlas)
# ==========================================
# Get free database: https://www.mongodb.com/atlas/database
# Format: mongodb+srv://username:password@cluster.mongodb.net/database

MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/vedurocks?retryWrites=true&w=majority
